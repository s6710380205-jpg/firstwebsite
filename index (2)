    <!-- Interactive JavaScript -->
    <script>
        // Theme Toggle Logic
        const htmlElement = document.documentElement;
        const themeToggleBtn = document.getElementById('theme-toggle');
        const themeToggleIcon = document.getElementById('theme-toggle-icon');
        const themeToggleBtnMobile = document.getElementById('theme-toggle-mobile');
        const themeToggleIconMobile = document.getElementById('theme-toggle-icon-mobile');

        // Check stored theme or system preference
        const currentTheme = localStorage.getItem('theme') || 'dark'; // default to dark
        
        if (currentTheme === 'dark') {
            htmlElement.classList.add('dark');
            updateIcons(true);
        } else {
            htmlElement.classList.remove('dark');
            updateIcons(false);
        }

        function updateIcons(isDark) {
            if (isDark) {
                themeToggleIcon.className = 'fa-solid fa-sun text-lg text-yellow-400';
                themeToggleIconMobile.className = 'fa-solid fa-sun text-lg text-yellow-400';
            } else {
                themeToggleIcon.className = 'fa-solid fa-moon text-lg text-slate-600';
                themeToggleIconMobile.className = 'fa-solid fa-moon text-lg text-slate-600';
            }
        }

        function toggleTheme() {
            if (htmlElement.classList.contains('dark')) {
                htmlElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
                updateIcons(false);
            } else {
                htmlElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                updateIcons(true);
            }
        }

        themeToggleBtn.addEventListener('click', toggleTheme);
        themeToggleBtnMobile.addEventListener('click', toggleTheme);

        // Mobile Menu Toggle
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        });

        // Close mobile menu when clicking a link
        document.querySelectorAll('#mobile-menu a').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.add('hidden');
            });
        });

        // Navbar blur effect on scroll
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 10) {
                nav.classList.add('shadow-lg');
            } else {
                nav.classList.remove('shadow-lg');
            }
        });

        // Interactive Code Generator Demo
        const generateBtn = document.getElementById('generateBtn');
        const vibeInput = document.getElementById('vibeInput');
        const loadingState = document.getElementById('loadingState');
        const codeOutput = document.getElementById('codeOutput');

        const dummyCode = `<!-- ปุ่มที่มีเอฟเฟกต์กระเพื่อม (Ripple Effect) -->
<button class="relative overflow-hidden bg-blue-600 text-white font-bold py-3 px-6 rounded-lg shadow-lg hover:bg-blue-700 transition-colors focus:outline-none group">
  <span class="relative z-10">คลิกที่นี่</span>
  <!-- เอฟเฟกต์กระเพื่อมใช้ CSS Animation พื้นฐาน -->
  <span class="absolute inset-0 bg-white/20 rounded-full opacity-0 group-active:animate-ping transition-all duration-500 scale-0 group-active:scale-150 origin-center"></span>
</button>

<style>
  /* เพิ่มลงในไฟล์ CSS หรือใช้ Tailwind classes */
</style>`;

        generateBtn.addEventListener('click', () => {
            if (!vibeInput.value.trim()) return;

            // Show loading
            loadingState.classList.remove('hidden');
            codeOutput.innerHTML = '';

            // Simulate API Call / Processing Time (1.5 seconds)
            setTimeout(() => {
                loadingState.classList.add('hidden');
                typeCode(dummyCode);
            }, 1500);
        });

        // Typewriter effect function
        function typeCode(code) {
            let i = 0;
            codeOutput.innerHTML = '';
            
            // Syntax Highlighting simple simulation
            const highlightedCode = code
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/&lt;button/g, '<span class="text-pink-400">&lt;button</span>')
                .replace(/&lt;\/button&gt;/g, '<span class="text-pink-400">&lt;/button&gt;</span>')
                .replace(/class=/g, '<span class="text-blue-300">class=</span>')
                .replace(/&lt;style&gt;/g, '<span class="text-pink-400">&lt;style&gt;</span>')
                .replace(/&lt;\/style&gt;/g, '<span class="text-pink-400">&lt;/style&gt;</span>')
                .replace(/&lt;span/g, '<span class="text-pink-400">&lt;span</span>')
                .replace(/&lt;\/span&gt;/g, '<span class="text-pink-400">&lt;/span&gt;</span>')
                .replace(/<!--(.*?)-->/g, '<span class="text-gray-500">&lt;!--$1--&gt;</span>')
                .replace(/\/\*(.*?)\*\//g, '<span class="text-gray-500">/*$1*/</span>');

            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = highlightedCode;
            const nodes = Array.from(tempDiv.childNodes);
            
            let htmlStr = '';
            
            // To make it look like typing, we'll just insert chunks quickly
            const interval = setInterval(() => {
                if (i < highlightedCode.length) {
                    htmlStr += highlightedCode.charAt(i);
                    codeOutput.innerHTML = htmlStr + '<span class="cursor-blink inline-block w-2 h-4 bg-gray-400 ml-1 translate-y-1"></span>';
                    i++;
                } else {
                    clearInterval(interval);
                    codeOutput.innerHTML = htmlStr; // remove cursor at the end
                }
            }, 10);
        }
        
        // Enter key to generate
        vibeInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                generateBtn.click();
            }
        });
    </script>
